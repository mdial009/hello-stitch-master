{
  "manifest_version": 2,
  "name": "Hello Stitch",
  "version": "1.0",
  "description": "A bookmarks manager with customizable title and themes",
  "permissions": [
    "bookmarks",
    "history"
  ],
  "icons": {
    "16": "icons/web/icons8-stitch-color-16.png",
    "48": "icons/web/icons8-stitch-color-48.png",
    "144": "icons/web/icons8-stitch-color-144.png"
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/web/icons8-stitch-color-16.png",
      "48": "icons/web/icons8-stitch-color-48.png",
      "144": "icons/web/icons8-stitch-color-144.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}
